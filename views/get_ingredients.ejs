<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Get Ingredients Needed</h1>
    <div class="form-control">
        <form action="/ingredients" method="POST">
            <label for="week-number">Input week number: </label>
            <input name="weekNumber" id="week-number" type="number" >
            <button type="submit" id="button-element" value="Get Ingredients">Get Ingredients</button> 
        </form>
    </div>

    <% if (error) { %>
        <p style="color: red;"><%= error %></p>
    <% } %>

    <% if (ingredients) { %>

        <h2>Ingredients For Week <%  weekNumber  %> </h2>
        <ul>
            <% ingredients.forEach(ingredient => { %>
                <li>
                    <%= ingredient.name %>: <%= ingredient.quantity %> <%= ingredient.unit %>
                </li>
            <% }); %>
        </ul>
    <% } %>

